# MongoDB connection string (MongoDB Atlas free tier works great)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/hireforge

# Secret used to sign JWT auth tokens - use a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret_string

# Base URL of the deployed app (used for absolute links, e.g. in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
